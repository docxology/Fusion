{
  "name": "hai-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx packages/cli/src/bin.ts",
    "dev:ui": "pnpm --filter @hai/dashboard dev",
    "build": "pnpm -r build",
    "build:exe": "pnpm build && pnpm --filter hai build:exe",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "koffi", "protobufjs"]
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
